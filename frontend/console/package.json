{
  "name": "antdv-next-pro",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "clean:cache": "rimraf node_modules/.cache/ && rimraf node_modules/.vite",
    "clean:lib": "rimraf node_modules",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "prepare": "cypress install",
    "test:e2e": "start-server-and-test preview http://localhost:4173 'cypress run --e2e'",
    "test:e2e:dev": "start-server-and-test 'vite dev --port 4173' http://localhost:4173 'cypress open --e2e'",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "oxfmt src/"
  },
  "dependencies": {
    "@antdv-next/happy-work-theme": "^1.0.0",
    "@antdv-next/icons": "^1.0.8",
    "@antdv-next/unocss": "^1.1.0",
    "@antdv-next1/pro-card": "^2.0.8",
    "@antdv-next1/pro-field": "^1.0.9",
    "@antdv-next1/pro-form": "^1.0.12",
    "@antdv-next1/pro-layout": "^1.0.12",
    "@antdv-next1/pro-provider": "^1.0.5",
    "@antdv-next1/pro-listy": "^1.0.5",
    "@antdv-next1/pro-table": "^1.0.15",
    "@antv/g2plot": "^2.4.35",
    "@iconify-json/ion": "^1.2.7",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/ri": "^1.2.10",
    "@iconify/vue": "^5.0.1",
    "@opd/g2plot-vue": "^4.0.1",
    "@v-c/util": "^1.0.19",
    "@vueuse/core": "^14.3.0",
    "antdv-next": "^1.3.6",
    "antdv-style": "0.1.0-alpha.1",
    "axios": "^1.17.0",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.21",
    "es-toolkit": "^1.47.1",
    "jsencrypt": "^3.5.4",
    "mockjs": "^1.1.0",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "qs": "^6.15.2",
    "vue": "^3.5.32",
    "vue-i18n": "^11.4.5",
    "vue-router": "^5.0.4",
    "vue-types": "^7.0.0"
  },
  "devDependencies": {
    "@antdv-next/auto-import-resolver": "^1.1.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/crypto-js": "^4.2.2",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.12.2",
    "@types/nprogress": "^0.2.3",
    "@types/qs": "^6.15.1",
    "@v-c/menu": "^1.2.0",
    "@vitejs/plugin-legacy": "^8.0.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vitest/eslint-plugin": "^1.6.16",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "cypress": "^15.14.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^6.3.1",
    "eslint-plugin-oxlint": "~1.60.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "less": "^4.6.6",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.45.0",
    "oxlint": "~1.60.0",
    "rimraf": "^6.1.3",
    "start-server-and-test": "^2.1.5",
    "typescript": "~6.0.0",
    "unocss": "^66.7.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.8",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-dayjs": "^1.0.2",
    "vite-plugin-mock": "^3.0.2",
    "vite-plugin-svg-icons": "^2.0.1",
    "vite-plugin-tsx-resolve-types": "^1.0.1",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vite-plugin-vue-resolve-types": "^0.0.1",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
